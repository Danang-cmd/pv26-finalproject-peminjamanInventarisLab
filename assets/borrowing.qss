/* ==========================================
   BORROWING.QSS
   Digunakan oleh: BorrowingPage (ui/borrowing.py)
   ========================================== */

/* --- LIGHT THEME (DEFAULT) --- */

QWidget[theme="light"] {
    background-color: #f8fafc;
    color: #0f172a;
}

/* Form Controls */
QLineEdit, QComboBox, QDateEdit {
    background-color: #ffffff;
    color: #0f172a;
    padding: 8px 12px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 13px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid #3b82f6;
}

/* Buttons */
QPushButton#ActionButton, QPushButton {
    background-color: #ffffff;
    color: #334155;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}

QPushButton#ActionButton:hover, QPushButton:hover {
    background-color: #f1f5f9;
    border-color: #94a3b8;
}

/* ── Tombol CRUD Borrowing ── */
QPushButton#PrimaryActionButton {
    background-color: #22c55e;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#PrimaryActionButton:hover {
    background-color: #16a34a;
}
QPushButton#PrimaryActionButton:pressed {
    background-color: #15803d;
}

QPushButton#BtnEdit {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#BtnEdit:hover {
    background-color: #2563eb;
}
QPushButton#BtnEdit:pressed {
    background-color: #1d4ed8;
}

QPushButton#BtnHapus {
    background-color: #ef4444;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#BtnHapus:hover {
    background-color: #dc2626;
}
QPushButton#BtnHapus:pressed {
    background-color: #b91c1c;
}

QPushButton#BtnExport {
    background-color: #f59e0b;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#BtnExport:hover {
    background-color: #d97706;
}
QPushButton#BtnExport:pressed {
    background-color: #b45309;
}

/* Table */
QTableWidget {
    background-color: #ffffff;
    alternate-background-color: #f8fafc;
    color: #334155;
    gridline-color: #e2e8f0;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

QHeaderView::section {
    background-color: #f1f5f9;
    color: #475569;
    padding: 10px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid #e2e8f0;
}

/* Status badge: Dipinjam */
QTableWidget QTableWidgetItem[status="Dipinjam"] {
    color: #b45309;
}

/* Status badge: Dikembalikan */
QTableWidget QTableWidgetItem[status="Dikembalikan"] {
    color: #15803d;
}

/* ==========================================
   DARK THEME OVERRIDES
   ========================================== */

QWidget[theme="dark"] {
    background-color: #0f172a;
    color: #f8fafc;
}

QWidget[theme="dark"] QLineEdit,
QWidget[theme="dark"] QComboBox,
QWidget[theme="dark"] QDateEdit {
    background-color: #1e293b;
    color: #f8fafc;
    border: 1px solid #475569;
}

QWidget[theme="dark"] QLineEdit:focus,
QWidget[theme="dark"] QComboBox:focus,
QWidget[theme="dark"] QDateEdit:focus {
    border: 1px solid #3b82f6;
}

QWidget[theme="dark"] QPushButton#ActionButton,
QWidget[theme="dark"] QPushButton {
    background-color: #1e293b;
    color: #e2e8f0;
    border: 1px solid #475569;
}

QWidget[theme="dark"] QPushButton#ActionButton:hover,
QWidget[theme="dark"] QPushButton:hover {
    background-color: #334155;
    border-color: #64748b;
}

/* ── Tombol CRUD dark theme ── */
QWidget[theme="dark"] QPushButton#PrimaryActionButton {
    background-color: #16a34a;
    color: #ffffff;
    border: none;
}
QWidget[theme="dark"] QPushButton#PrimaryActionButton:hover { background-color: #15803d; }

QWidget[theme="dark"] QPushButton#BtnEdit {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
}
QWidget[theme="dark"] QPushButton#BtnEdit:hover { background-color: #1d4ed8; }

QWidget[theme="dark"] QPushButton#BtnHapus {
    background-color: #dc2626;
    color: #ffffff;
    border: none;
}
QWidget[theme="dark"] QPushButton#BtnHapus:hover { background-color: #b91c1c; }

QWidget[theme="dark"] QPushButton#BtnExport {
    background-color: #d97706;
    color: #ffffff;
    border: none;
}
QWidget[theme="dark"] QPushButton#BtnExport:hover { background-color: #b45309; }

QWidget[theme="dark"] QTableWidget {
    background-color: #1e293b;
    alternate-background-color: #111827;
    color: #e2e8f0;
    gridline-color: #334155;
    border: 1px solid #334155;
}

QWidget[theme="dark"] QHeaderView::section {
    background-color: #111827;
    color: #cbd5e1;
    border-bottom: 2px solid #334155;
}

QWidget[theme="dark"] QLabel {
    color: #cbd5e1;
}
